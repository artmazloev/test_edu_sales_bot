TELEGRAM_TOKEN=your_telegram_bot_token_here
LOG_LEVEL=INFO

# Провайдер моделей: yandex (по умолчанию) или openai
LLM_PROVIDER=yandex

# --- Yandex Cloud (нужно при LLM_PROVIDER=yandex) ---
YANDEX_API_KEY=your_yandex_api_key_here
YANDEX_FOLDER_ID=your_folder_id_here
YANDEX_GPT_MODEL=yandexgpt
YANDEX_TTS_VOICE=filipp
YANDEX_TTS_SPEED=1.2
YANDEX_STT_LANG=ru-RU

# --- OpenAI (нужно при LLM_PROVIDER=openai) ---
OPENAI_API_KEY=your_openai_api_key_here
